{
  "enabled": {
    "description": "启用 Markdown 文本渲染器",
    "type": "bool",
    "default": true
  },
  "mode": {
    "description": "输出模式",
    "type": "string",
    "default": "ascii",
    "hint": "可选 ascii 或 plain"
  },
  "table_mode": {
    "description": "表格渲染模式",
    "type": "string",
    "default": "ascii",
    "hint": "可选 ascii 或 plain"
  },
  "keep_links": {
    "description": "保留链接 URL",
    "type": "bool",
    "default": true
  },
  "keep_code_language": {
    "description": "保留代码块语言标签",
    "type": "bool",
    "default": true
  },
  "preserve_inline_semantics": {
    "description": "保留强调和删除线的文本语义标记",
    "type": "bool",
    "default": true
  },
  "strip_html": {
    "description": "移除 HTML 标签",
    "type": "bool",
    "default": true
  },
  "detect_markdown_only": {
    "description": "仅在检测到 Markdown 特征时处理",
    "type": "bool",
    "default": true
  },
  "aiocqhttp_only": {
    "description": "仅在 aiocqhttp 平台启用渲染",
    "type": "bool",
    "default": false
  },
  "debug_log": {
    "description": "输出调试日志",
    "type": "bool",
    "default": false
  }
}
